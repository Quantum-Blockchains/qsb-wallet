{
  "author": "Jaco Greeff <jacogr@gmail.com>",
  "bugs": "https://github.com/polkadot-js/extension/issues",
  "engines": {
    "node": ">=18.14"
  },
  "homepage": "https://github.com/polkadot-js/extension#readme",
  "license": "Apache-2.0",
  "packageManager": "yarn@3.2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/polkadot-js/extension.git"
  },
  "sideEffects": false,
  "type": "module",
  "version": "0.46.8",
  "versions": {
    "git": "0.46.8",
    "npm": "0.46.8"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "./scripts/build.sh",
    "build:before": "yarn build:i18n",
    "build:chrome": "cp ./packages/extension/manifest_chrome.json ./packages/extension/manifest.json && polkadot-dev-build-ts && yarn build:zip:chrome && yarn build:rollup",
    "build:extension": "yarn build:chrome",
    "build:ff": "cp ./packages/extension/manifest_firefox.json ./packages/extension/manifest.json && polkadot-dev-build-ts && yarn build:zip:ff && yarn build:rollup",
    "build:i18n": "i18next-scanner --config i18next-scanner.config.cjs",
    "build:release": "polkadot-ci-ghact-build",
    "build:rollup": "polkadot-exec-rollup --config",
    "build:zip": "yarn build:zip:chrome && yarn build:zip:ff",
    "build:zip:chrome": "cp ./packages/extension/manifest_chrome.json ./packages/extension/manifest.json && yarn build:zip:dst:chrome && yarn build:zip:src:chrome",
    "build:zip:dst": "yarn build:zip:dst:ff",
    "build:zip:dst:chrome": "rm -rf ./master-chrome-build.zip && cd packages/extension/build && zip -r -FS ../../../master-chrome-build.zip .",
    "build:zip:dst:ff": "rm -rf ./master-ff-build.zip && cd packages/extension/build && zip -r -FS ../../../master-ff-build.zip .",
    "build:zip:ff": "cp ./packages/extension/manifest_firefox.json ./packages/extension/manifest.json && yarn build:zip:dst:ff && yarn build:zip:src:ff",
    "build:zip:src": "yarn build:zip:src:ff",
    "build:zip:src:chrome": "rm -rf ./master-chrome-src.zip && zip -r -x '*build/*' -x '*node_modules*' -FS ./master-chrome-src.zip packages .editorconfig .eslintignore .eslintrc.js babel.config.cjs CHANGELOG.md CONTRIBUTING.md i18next-scanner.config.js LICENSE package.json README.md tsconfig.json yarn.lock",
    "build:zip:src:ff": "rm -rf ./master-ff-src.zip && zip -r -x '*build/*' -x '*node_modules*' -FS ./master-ff-src.zip packages .editorconfig .eslintignore .eslintrc.js babel.config.cjs CHANGELOG.md CONTRIBUTING.md i18next-scanner.config.js LICENSE package.json README.md tsconfig.json yarn.lock",
    "clean": "polkadot-dev-clean-build",
    "lint": "polkadot-dev-run-lint",
    "postinstall": "polkadot-dev-yarn-only",
    "start": "yarn watch",
    "test": "EXTENSION_PREFIX='test' polkadot-dev-run-test --loader ./packages/extension-mocks/src/loader-empty.js --env browser ^:.spec.tsx",
    "test:one": "EXTENSION_PREFIX='test' polkadot-dev-run-test --env browser",
    "watch": "cd packages/extension && yarn polkadot-exec-webpack --config webpack.watch.cjs --mode development --watch"
  },
  "devDependencies": {
    "@polkadot/dev": "^0.75.19",
    "@types/node": "^20.2.5",
    "i18next-scanner": "^4.2.0",
    "sinon-chrome": "^3.0.1"
  },
  "resolutions": {
    "@polkadot/api": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-api-10.9.1.tgz",
    "@polkadot/api-augment": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-api-augment-10.9.1.tgz",
    "@polkadot/api-base": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-api-base-10.9.1.tgz",
    "@polkadot/api-derive": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-api-derive-10.9.1.tgz",
    "@polkadot/hw-ledger": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-hw-ledger-12.3.2.tgz",
    "@polkadot/hw-ledger-transports": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-hw-ledger-transports-12.3.2.tgz",
    "@polkadot/keyring": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-keyring-12.3.2.tgz",
    "@polkadot/networks": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-networks-12.3.2.tgz",
    "@polkadot/phishing": "^0.21.5",
    "@polkadot/react-identicon": "https://github.com/Quantum-Blockchains/ui/releases/download/v3.5.1/polkadot-react-identicon-3.5.1.tgz",
    "@polkadot/react-qr": "https://github.com/Quantum-Blockchains/ui/releases/download/v3.5.1/polkadot-react-qr-3.5.1.tgz",
    "@polkadot/rpc-augment": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-rpc-augment-10.9.1.tgz",
    "@polkadot/rpc-core": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-rpc-core-10.9.1.tgz",
    "@polkadot/rpc-provider": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-rpc-provider-10.9.1.tgz",
    "@polkadot/types": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-types-10.9.1.tgz",
    "@polkadot/types-augment": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-types-augment-10.9.1.tgz",
    "@polkadot/types-codec": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-types-codec-10.9.1.tgz",
    "@polkadot/types-create": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-types-create-10.9.1.tgz",
    "@polkadot/types-known": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-types-known-10.9.1.tgz",
    "@polkadot/types-support": "https://github.com/Quantum-Blockchains/api/releases/download/v10.9.1/polkadot-types-support-10.9.1.tgz",
    "@polkadot/ui-keyring": "https://github.com/Quantum-Blockchains/ui/releases/download/v3.5.1/polkadot-ui-keyring-3.5.1.tgz",
    "@polkadot/ui-settings": "https://github.com/Quantum-Blockchains/ui/releases/download/v3.5.1/polkadot-ui-settings-3.5.1.tgz",
    "@polkadot/ui-shared": "https://github.com/Quantum-Blockchains/ui/releases/download/v3.5.1/polkadot-ui-shared-3.5.1.tgz",
    "@polkadot/util": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-util-12.3.2.tgz",
    "@polkadot/util-crypto": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-util-crypto-12.3.2.tgz",
    "@polkadot/wasm-bridge": "https://github.com/Quantum-Blockchains/wasm/releases/download/v7.2.1/polkadot-wasm-bridge-7.2.1.tgz",
    "@polkadot/wasm-crypto": "https://github.com/Quantum-Blockchains/wasm/releases/download/v7.2.1/polkadot-wasm-crypto-7.2.1.tgz",
    "@polkadot/wasm-crypto-asmjs": "https://github.com/Quantum-Blockchains/wasm/releases/download/v7.2.1/polkadot-wasm-crypto-asmjs-7.2.1.tgz",
    "@polkadot/wasm-crypto-init": "https://github.com/Quantum-Blockchains/wasm/releases/download/v7.2.1/polkadot-wasm-crypto-init-7.2.1.tgz",
    "@polkadot/wasm-crypto-wasm": "https://github.com/Quantum-Blockchains/wasm/releases/download/v7.2.1/polkadot-wasm-crypto-wasm-7.2.1.tgz",
    "@polkadot/wasm-util": "https://github.com/Quantum-Blockchains/wasm/releases/download/v7.2.1/polkadot-wasm-util-7.2.1.tgz",
    "@polkadot/x-bigint": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-x-bigint-12.3.2.tgz",
    "@polkadot/x-fetch": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-x-fetch-12.3.2.tgz",
    "@polkadot/x-global": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-x-global-12.3.2.tgz",
    "@polkadot/x-randomvalues": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-x-randomvalues-12.3.2.tgz",
    "@polkadot/x-textdecoder": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-x-textdecoder-12.3.2.tgz",
    "@polkadot/x-textencoder": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-x-textencoder-12.3.2.tgz",
    "@polkadot/x-ws": "https://github.com/Quantum-Blockchains/common/releases/download/v12.3.2/polkadot-x-ws-12.3.2.tgz",
    "safe-buffer": "^5.2.1",
    "typescript": "^5.0.3"
  }
}
